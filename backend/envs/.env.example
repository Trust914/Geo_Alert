# ── Application Configuration ──────────────────────────────────
API_NAME=GeoAlert_API
APP_VERSION=v1
NODE_ENV=development
PORT=3000
FRONT_END_DOMAIN=http://localhost:5173

# ── Database (PostgreSQL) ──────────────────────────────────────
PG_DB_USER=postgres
PG_DB_PASSWORD=your_secure_password_here
PG_DB_HOST=localhost
PG_DB_PORT=5432
PG_DB_NAME=geo_alert_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_DEV_HOST=localhost
REDIS_DOCKER_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=your_redis_password_here

# ── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_DEV_HOST=localhost
RABBITMQ_DOCKER_HOST=rabbitmq
RABBITMQ_PORT=5673
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password_here
RABBITMQ_EXCHANGE=geoalert.exchange

# ── Security & Authentication ──────────────────────────────────
# Use: openssl rand -base64 32 to generate secrets
JWT_ACCESS_TOKEN_SECRET=your_access_token_secret
JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret
JWT_2FA_TOKEN_SECRET=your_2fa_token_secret
JWT_VERIFY_TOKEN_SECRET=your_verify_token_secret

TWO_FACTOR_ENCRYPTION_KEY=your_32_byte_hex_key
CYPHER_ALGORITHM=aes-256-cbc
SALT_ROUNDS=12

# ── Email (SMTP) ───────────────────────────────────────────────
SMTP_SERVICE=gmail
SMTP_PORT=465
SMTP_USER=example@gmail.com
SMTP_CLIENT_ID=your_google_client_id
SMTP_CLIENT_SECRET=your_google_client_secret
SMTP_REFRESH_TOKEN=your_google_refresh_token

# ── AfricasTalking (SMS/USSD) ──────────────────────────────────
AT_USERNAME_DEV=sandbox
AT_API_KEY_DEV=your_at_dev_api_key
AT_SHORT_CODE_DEV=867

# ── Seeding Paths ──────────────────────────────────────────────
SEED_STATE_FILE_PATH=./src/seed/data/states.geojson
SEED_LGA_FILE_PATH=./src/seed/data/lgas.geojson
SEED_WARD_FILE_PATH=./src/seed/data/wards.geojson
SEED_POPULATION_FILE_PATH=./src/seed/data/population.geojson

# ── Rate Limiting & Performance ────────────────────────────────
ENDPOINT_LIMIT=20
RATELIMITER_REDIS_MAX_POINTS=50
MAX_LOG_FILE_SIZE=5242880