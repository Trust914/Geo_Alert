{
  "name": "geoalert-api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest",
    "test.dev": "cross-env NODE_ENV=development vitest",
    "test.staging": "cross-env NODE_ENV=staging vitest",
    "test.prod": "cross-env NODE_ENV=production vitest",
    "testrun.dev": "cross-env NODE_ENV=development vitest run",
    "testrun.staging": "cross-env NODE_ENV=staging vitest run",
    "testrun.prod": "cross-env NODE_ENV=production vitest run",
    "test.coverage.dev": "cross-env NODE_ENV=development vitest --coverage",
    "test.coverage.staging": "cross-env NODE_ENV=staging vitest --coverage",
    "test.coverage.prod": "cross-env NODE_ENV=production vitest --coverage",
    "test.unit.dev": "cross-env NODE_ENV=development vitest run --reporter=verbose src/__tests__/unit/",
    "test.unit.staging": "cross-env NODE_ENV=staging vitest run --reporter=verbose src/__tests__/unit/",
    "test.unit.prod": "cross-env NODE_ENV=production vitest run --reporter=verbose src/__tests__/unit/",
    "test.integration.dev": "cross-env NODE_ENV=development vitest run --reporter=verbose src/__tests__/integration/",
    "test.integration.staging": "cross-env NODE_ENV=staging vitest run --reporter=verbose src/__tests__/integration/",
    "test.integration.prod": "cross-env NODE_ENV=production vitest run --reporter=verbose src/__tests__/integration/",
    "test.performance.dev": "cross-env NODE_ENV=development vitest run --reporter=verbose src/__tests__/performance/",
    "test.performance.staging": "cross-env NODE_ENV=staging vitest run --reporter=verbose src/__tests__/performance/",
    "test.performance.prod": "cross-env NODE_ENV=production vitest run --reporter=verbose src/__tests__/performance/",
    "seed": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/seed.ts all\"",
    "docker.seed.geo": "sh scripts/seed.sh src/seed/seed.ts geo",
    "seed.geo": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/seed.ts geo\"",
    "seed.geo.states": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/geoSpatial.ts state\"",
    "seed.geo.lgas": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/geoSpatial.ts lga\"",
    "seed.geo.wards": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/geoSpatial.ts ward\"",
    "docker.seed.admin": "sh scripts/seed.sh src/seed/firstAdmin.ts",
    "seed.admin": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/firstAdmin.ts\"",
    "docker.seed.population": "sh scripts/seed.sh src/seed/population.ts",
    "seed.test.citizens": "cross-env-shell \"npx tsx --env-file=envs/.env.${NODE_ENV:-development} src/seed/seedGeoTestCitizens.ts\"",
    "build": "npm run clean && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@prisma/client --external:argon2 --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start.dev": "tsx watch --env-file=envs/.env.development src/index.ts",
    "start.staging": "node --trace-warnings dist/index.js",
    "start.prod": "node --trace-warnings dist/index.js",
    "prisma.generate": "npx prisma generate --schema=./src/prisma/",
    "prisma.migrate": "npx prisma migrate dev",
    "prisma.deploy": "npx prisma migrate deploy --schema=./src/prisma/",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@types/africastalking": "^0.6.2",
    "@types/amqplib": "^0.10.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.5",
    "@types/geojson": "^7946.0.16",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/stream-json": "^1.7.8",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "prisma": "^7.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^3.0.4",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "@types/express-rate-limit": "^5.1.3",
    "africastalking": "^0.7.8",
    "amqplib": "^0.10.9",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.66.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "fs": "^0.0.1-security",
    "geojson": "^0.5.0",
    "googleapis": "^170.1.0",
    "helmet": "^8.1.0",
    "http-status": "^2.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.11",
    "otplib": "^12.0.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.0",
    "rate-limiter-flexible": "^9.0.0",
    "stream-json": "^1.9.1",
    "winston": "^3.18.3",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.2.1"
  }
}
