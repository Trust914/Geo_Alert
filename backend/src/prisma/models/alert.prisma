model Alert {
  id       String @id @default(cuid(2))
  agencyId String @map("agency_id")
  agency   Agency @relation(fields: [agencyId], references: [id])

  // Creator (Must exist, enforced by NoAction)
  createdByUserId String   @map("created_by_user_id")
  createdBy       User     @relation(fields: [createdByUserId], references: [id], onDelete: NoAction)
  createdAt       DateTime @default(now()) @map("created_at")

  // --- NEW: SENDING TRACKING ---
  sentByUserId    String?   @map("sent_by_user_id")
  sentBy          User?     @relation("AlertSender", fields: [sentByUserId], references: [id])
  sentAt          DateTime? @map("sent_at")

  // --- NEW: CANCELLATION TRACKING ---
  cancelledByUserId String?   @map("cancelled_by_user_id")
  cancelledBy       User?     @relation("AlertCanceller", fields: [cancelledByUserId], references: [id])
  cancelledAt       DateTime? @map("cancelled_at")
  cancelReason      String?   @map("cancel_reason") @db.Text

  category    AlertCategory
  severity    Severity
  urgency     Urgency
  headline    String
  description String        @db.Text
  instruction String?       @db.Text
  capXml      String        @map("cap_xml") @db.Text

  status       AlertStatus @default(DRAFT)

  // Geospatial Data
  affectedArea     Unsupported("geometry(MultiPolygon, 4326)")? @map("affected_area")
  incidentLocation Unsupported("geometry(Point, 4326)")?        @map("incident_location")

  // sentAt    DateTime? @map("sent_at")
  expiresAt DateTime? @map("expires_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  targets    AlertTarget[]
  deliveries DeliveredAlert[]

  @@index([agencyId])
  @@index([createdByUserId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@index([affectedArea], type: Gist)
  @@index([incidentLocation], type: Gist)
  @@map("alerts")
}

model AlertTarget {
  id      String @id @default(cuid(2))
  alertId String @map("alert_id")
  alert   Alert  @relation(fields: [alertId], references: [id], onDelete: Cascade)

  targetType TargetType @map("target_type")

  // Targeted Areas
  stateId String? @map("state_id")
  state   State?  @relation(fields: [stateId], references: [id])
  lgaId   String? @map("lga_id")
  lga     LGA?    @relation(fields: [lgaId], references: [id])
  wardId  String? @map("ward_id")
  ward    Ward?   @relation(fields: [wardId], references: [id])

  // Advanced Targeting
  radiusMeters     Int?                                       @map("radius_meters")
  centerPoint      Unsupported("geometry(Point, 4326)")?      @map("center_point")
  targetPolygon    Unsupported("geometry(Polygon, 4326)")?    @map("target_polygon")
  targetPath       Unsupported("geometry(LineString, 4326)")? @map("target_path")
  pathBufferMeters Int?                                       @map("path_buffer_meters")

  estimatedRecipients Int?     @map("estimated_recipients")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([alertId])
  @@index([stateId])
  @@index([lgaId])
  @@index([wardId])
  @@index([centerPoint], type: Gist)
  @@index([targetPolygon], type: Gist)
  @@index([targetPath], type: Gist)
  @@map("alert_targets")
}
