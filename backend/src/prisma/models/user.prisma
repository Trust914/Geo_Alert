model User {
  id           String   @id @default(cuid(2))
  email        String   @unique
  passwordHash String?  @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phoneNumber  String?  @unique @map("phone_number")
  role         UserRole

  // Membership: User belongs to an Agency
  agencyId String @map("agency_id")
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // Security & Status
  lastLoginAt        DateTime? @map("last_login_at")
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Verification
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")

  // 2FA Security Fields
  isTwoFactorEnabled   Boolean         @default(false)
  twoFactorMethod      TwoFactorMethod @default(NONE)
  twoFactorSecret      String? // Stored ENCRYPTED
  twoFactorBackupCodes String[] // Stored HASHED (Argon2) or ENCRYPTED

  // Self-Relation: Who created this user?
  createdById String? @map("created_by_id")
  createdBy   User?   @relation("UserCreator", fields: [createdById], references: [id], onDelete: NoAction)

  // Inverse: Users created by this user
  createdUsers User[] @relation("UserCreator")

  // Inverse: Agencies created by this user
  createdAgencies Agency[] @relation("AgencyCreator")

  sentAlerts      Alert[] @relation("AlertSender")
  cancelledAlerts Alert[] @relation("AlertCanceller")

  // Other Relations
  alerts        Alert[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  @@index([agencyId])
  @@index([email])
  @@index([isActive])
  @@index([mustChangePassword])
  @@index([emailVerified])
  @@map("users")
}

model Citizen {
  id          String @id @default(cuid(2))
  phoneNumber String @unique @map("phone_number")
  firstName   String @map("first_name")
  lastName    String @map("last_name")

  // Location Relations
  stateId String  @map("state_id")
  state   State   @relation(fields: [stateId], references: [id])
  lgaId   String  @map("lga_id")
  lga     LGA     @relation(fields: [lgaId], references: [id])
  wardId  String? @map("ward_id")
  ward    Ward?   @relation(fields: [wardId], references: [id])

  location          Unsupported("geometry(Point, 4326)")?
  preferredLanguage Language                              @default(ENGLISH) @map("preferred_language")
  isOptedIn         Boolean                               @default(true) @map("is_opted_in")
  registeredAt      DateTime                              @default(now()) @map("registered_at")
  updatedAt         DateTime                              @updatedAt @map("updated_at")

  deliveries DeliveredAlert[]

  @@index([phoneNumber])
  @@index([stateId])
  @@index([lgaId])
  @@index([wardId])
  @@index([isOptedIn])
  @@index([location], type: Gist)
  @@map("citizens")
}

model RefreshToken {
  id     String @id @default(cuid(2))
  token  String @unique
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  isRevoked Boolean   @default(false) @map("is_revoked")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([isRevoked])
  @@map("refresh_tokens")
}
